{
  "name": "civickit-web",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  },
  "scripts": {
    "dev": "portless civickit-web --force vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy --env production",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
